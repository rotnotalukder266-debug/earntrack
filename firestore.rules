rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.admin == true;
    }

    // ইউজার প্রোফাইল
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
    }

    // সাবস্ক্রিপশন — ইউজার শুধু "pending" স্ট্যাটাসে রিকোয়েস্ট করতে পারবে
    // active/rejected করতে পারবে কেবল admin
    match /subscriptions/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && request.resource.data.status == "pending";
      allow update: if isAdmin();
    }

    // টাস্ক তালিকা — সবাই পড়তে পারবে, শুধু admin যোগ/সম্পাদনা করতে পারবে
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // টাস্ক জমা — ইউজার নিজেরটা "pending" হিসেবে জমা দিতে পারবে
    // approve/reject করতে পারবে কেবল admin
    match /submissions/{subId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "pending";
      allow update: if isAdmin();
    }

    // উত্তোলন অনুরোধ — একইভাবে
    match /withdrawals/{wId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "pending";
      allow update: if isAdmin();
    }

    // ওয়ালেট ব্যালেন্স — ইউজার নিজে কখনো এডিট করতে পারবে না, শুধু admin (approve action এর মাধ্যমে)
    match /wallets/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // ভিডিও তালিকা — সবাই পড়তে পারবে, শুধু admin যোগ/সম্পাদনা করতে পারবে
    match /videos/{videoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // এডমিন রোল — কখনো ক্লায়েন্ট থেকে লেখা যাবে না, শুধু Firebase Console থেকে ম্যানুয়ালি সেট করতে হবে
    match /roles/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }
  }
}
